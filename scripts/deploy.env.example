# Deployment configuration for the Claude apps gateway stacks.
#
#   cp scripts/deploy.env.example scripts/deploy.env   # deploy.env is gitignored
#   vi scripts/deploy.env
#
# Every scripts/*.sh sources this file. Values marked (required) have no
# usable default and must be set before running the deploy scripts.

# --- AWS ---------------------------------------------------------------
export AWS_REGION="us-gov-west-1"
# export AWS_PROFILE="govcloud"          # uncomment if you use a named profile

# --- Naming ------------------------------------------------------------
# Must match between both stacks (02-gateway.yaml imports 01-database.yaml
# exports by this prefix).
export NAME_PREFIX="claude-gw"
export DB_STACK_NAME="${NAME_PREFIX}-db"
export GATEWAY_STACK_NAME="${NAME_PREFIX}"
export OBS_STACK_NAME="${NAME_PREFIX}-obs"

# --- Network (required) ------------------------------------------------
# FIRST DECISION - does this VPC have NAT egress of its own?
#   NAT-equipped VPC:     the defaults below work as-is.
#   Landing-zone spoke (no NAT, TGW to central egress): a copy-paste deploy
#   FAILS at image pull unless you either set the three endpoint switches in
#   the "VPC endpoints" section below (recommended) or your TGW->central-NAT
#   path is allowlisted for ECR/S3 at the inspection firewall. See README
#   "ZPA & landing-zone prerequisites".
export VPC_ID=""                          # vpc-xxxxxxxx
export VPC_CIDR="10.20.0.0/16"            # used for listen.trusted_proxies
export PRIVATE_SUBNET_IDS=""              # comma-separated, >=2 AZs: subnet-aaa,subnet-bbb
# CIDR the ALB accepts 443 from. With ZPA this must cover the App
# CONNECTORS' source IPs (users arrive from connector IPs, not their own or
# CGNAT ranges) - and narrow it: 10.0.0.0/8 is an auditor finding, and
# on-prem connectors in 172.16/12 or 192.168/16 would be silently dropped.
export CLIENT_INGRESS_CIDR="10.0.0.0/8"   # NARROW THIS: ZPA App Connector subnets / VPN pool

# --- TLS / DNS (required) ----------------------------------------------
# ARN printed by scripts/import-enterprise-cert.sh import ...
export CERTIFICATE_ARN=""
# Corporate CNAME developers will use, e.g. claude-gateway.example.com
export GATEWAY_FQDN=""

# --- Container image ----------------------------------------------------
# Pinned Claude Code version baked into the gateway image (>= 2.1.195).
export CLAUDE_VERSION="2.1.207"
export ECR_REPO_NAME="claude-gateway"
# Leave IMAGE_URI empty to derive it from the current account + ECR_REPO_NAME.
export IMAGE_URI=""
# DB admin Lambda image (app-user bootstrap + secret rotation), built by
# scripts/build-and-push-dbadmin.sh (required for deploy-gateway.sh).
export DBADMIN_IMAGE=""
# App DB secret rotation cadence. Alternating users: the previous
# credential stays valid until the NEXT rotation.
export APP_SECRET_ROTATION_DAYS="90"

# --- Okta (required) ----------------------------------------------------
# Custom authorization server recommended, e.g. https://your-org.okta.com/oauth2/default
export OKTA_ISSUER=""
export OKTA_CLIENT_ID=""
# Comma-separated sign-in email domains, e.g. example.com,example.gov
export ALLOWED_EMAIL_DOMAINS=""

# --- Models ---------------------------------------------------------------
# Developers get a two-model menu in Claude Code: Opus and Sonnet. The
# *_MODEL_ID is what they see; the *_BEDROCK_MODEL_ID is the GovCloud
# inference profile the gateway invokes. Defaults are Claude Opus 4.8 and
# Claude Sonnet 4.5 — the newest of each tier available in GovCloud (note
# Opus 4.8 uses the new un-dated ID format; Sonnet 4.5 keeps -v1:0).
# Confirm with: aws bedrock list-inference-profiles --region us-gov-west-1
export OPUS_MODEL_ID="claude-opus-4-8"
export OPUS_BEDROCK_MODEL_ID="us-gov.anthropic.claude-opus-4-8"
export SONNET_MODEL_ID="claude-sonnet-4-5"
export SONNET_BEDROCK_MODEL_ID="us-gov.anthropic.claude-sonnet-4-5-20250929-v1:0"

# --- Encryption ------------------------------------------------------------
# Customer-managed KMS key for everything at rest (RDS, secrets, CloudWatch
# logs, activity archive, AMP; ECR repos at creation). Leave empty and the
# database stack creates one (rotation enabled). Landing zones with central
# key management: pass the mandated key ARN - its policy must allow the
# CloudWatch Logs service principal (see the KmsKey resource in
# 01-database.yaml for the exact statement). The ALB access-logs bucket
# stays SSE-S3: ELB log delivery does not support KMS.
# The database stack persists the resolved key back here so the ECR repos
# created afterwards are CMK-encrypted (deploy 01 before the first image
# push - see README quick start). NOTE: the RDS storage key is a DAY-ONE
# decision - adopting/changing it on an existing deployment requires the
# teardown+restore migration in README "Teardown & update order".
export KMS_KEY_ARN=""

# --- Database ------------------------------------------------------------
# RDS Postgres MINOR versions vary by region and are deprecated over time.
# Leave empty to use the template default, or pin a currently-available 16.x
# (must be 16.x - the parameter group family is postgres16). Find valid ones:
#   aws rds describe-db-engine-versions --engine postgres --region us-gov-west-1 \
#     --query "DBEngineVersions[?starts_with(EngineVersion,'16.')].EngineVersion" --output text
export DB_ENGINE_VERSION=""
# pgaudit classes exported to the postgresql CloudWatch log (AU-2/AU-3).
# Add 'read' to audit SELECTs at a real volume cost.
export PGAUDIT_LOG_CLASSES="ddl,role,write"

# --- Gateway service ----------------------------------------------------
export DESIRED_COUNT="2"
export SESSION_TTL_HOURS="1"
# Valid Fargate pairings only (the stack validates at deploy time):
# 512cpu/1-4GB, 1024/2-8GB, 2048/4-16GB, 4096/8-30GB, in 1024MB steps.
export TASK_CPU="1024"
export TASK_MEMORY="2048"
# ALB idle timeout: must exceed the longest silent gap in a streaming
# response (extended thinking can go minutes with no bytes on the wire).
export ALB_IDLE_TIMEOUT_SECONDS="900"
# Drain time on every rolling deploy. Streams still open when a deploy
# starts are cut after THIS long, and every deploy waits the full delay -
# 300 = +5 min per deploy. Raise toward the idle timeout only if cutting
# long turns during deploys is unacceptable.
export DEREGISTRATION_DELAY_SECONDS="300"
# Egress proxy for public endpoints (Okta OIDC). Set when the landing zone
# mandates a central proxy for internet egress; leave empty when egress is
# NAT-based (local, or a Transit Gateway egress VPC — TGW is transitive, so
# central NAT works). AWS APIs and the DB bypass the proxy via NO_PROXY,
# keeping Bedrock on the VPC endpoint either way.
# (Also injected into the Grafana task by deploy-observability.sh - its
# server-side Okta OAuth calls are public egress too.)
export HTTPS_PROXY_URL=""                  # e.g. http://proxy.corp.example.com:3128

# --- Observability (03-observability.yaml) --------------------------------
# Grafana image built by scripts/build-and-push-grafana.sh (required for
# deploy-observability.sh). Collector image (required): mirror a PINNED ADOT
# release into your ECR and reference it by digest - the task can't reach
# public.ecr.aws from a locked-down spoke, and an unpinned tag is a
# supply-chain risk:
#   docker pull public.ecr.aws/aws-observability/aws-otel-collector:v0.43.0
#   docker tag ... <acct>.dkr.ecr.<region>.amazonaws.com/adot-collector:v0.43.0
#   docker push ...   # then set the pushed image's @sha256:<digest> URI here
# The Grafana ECR repo is tag-immutable; when you change docker/grafana/
# provisioning without bumping Grafana, rebuild with GRAFANA_IMAGE_TAG=<new>.
export GRAFANA_IMAGE=""
export COLLECTOR_IMAGE=""
# 2 keeps the OTLP target resolvable through collector rollouts at the cost
# of a second always-on task (~256cpu/512MB); 1 is fine if a seconds-long
# metrics gap on rare redeploys is acceptable.
export COLLECTOR_DESIRED_COUNT="2"
export CREATE_AMP_ENDPOINT="false"         # aps-workspaces interface endpoint (no-NAT VPCs)
# AMP's KMS key is fixed at workspace creation: 'true' on an EXISTING
# deployment REPLACES the workspace and orphans all usage/cost history -
# existing deployments keep 'false' unless starting fresh is acceptable.
export ENCRYPT_AMP_WITH_CMK="true"
# Grafana auth = Okta SSO (per-user accounts; no shared admin password).
# Reuse the gateway's Okta app: add the redirect URI
# https://<GATEWAY_FQDN>/grafana/login/generic_oauth to it and set
# GRAFANA_OKTA_CLIENT_ID=$OKTA_CLIENT_ID (secret via
# scripts/set-grafana-oidc-secret.sh) - or register a dedicated app.
# OKTA_ISSUER above is reused for Grafana. Set OKTA_AUTH_SERVER_TYPE to
# match how it's built:
#   org    - the built-in org server; OKTA_ISSUER is the bare domain
#            (https://org.okta.com, no trailing slash). Grafana's endpoints
#            are derived under /oauth2/v1/..., and the org server's built-in
#            'groups' scope returns groups (request it - which Grafana does).
#   custom - a custom authorization server; OKTA_ISSUER ends in /oauth2/<id>
#            and you configure a groups scope + claim on it.
# Role mapping is strict: users in none of these groups cannot log in.
export OKTA_AUTH_SERVER_TYPE="org"
export GRAFANA_OKTA_CLIENT_ID=""
export GRAFANA_ADMIN_GROUP="grafana-admins"
export GRAFANA_EDITOR_GROUP=""
export GRAFANA_VIEWER_GROUP=""
export GRAFANA_DISABLE_LOGIN_FORM="true"   # false = temporary break-glass 'admin' form login
# After deploying 03, set to its OtlpForwardUrl output and re-run
# deploy-gateway.sh — the gateway then forwards all telemetry (its own +
# every client's, stamped with Okta user/groups) to the collector.
export OBSERVABILITY_OTLP_URL=""           # e.g. http://otel-collector.claude-gw.internal:4318
# AI activity audit stream (bash commands, tool inputs, file paths per user;
# prompts stay redacted). HIGHLY SENSITIVE — enable only where an audit
# trail is required. Flows into a short CloudWatch window then an S3
# archive; the pipeline exists either way and is free while idle.
export FORWARD_ACTIVITY_LOGS="false"
export ACTIVITY_LOG_WINDOW_DAYS="14"       # CloudWatch operational window
export ACTIVITY_ARCHIVE_RETENTION_DAYS="731"  # S3 archive expiry

# --- Monitoring -----------------------------------------------------------
# The stack always creates the ALB access-logs bucket and a CloudWatch alarm
# on the certificate's DaysToExpiry (imported ACM certs do not auto-renew).
export CERT_EXPIRY_ALARM_DAYS="30"
export ALARM_SNS_TOPIC_ARN=""              # optional: notify on cert expiry
export ALB_LOG_RETENTION_DAYS="90"

# --- VPC endpoints --------------------------------------------------------
# Landing-zone spoke with no NAT? You almost certainly want all three:
#   CREATE_SUPPORTING_ENDPOINTS="true"  PRIVATE_ROUTE_TABLE_IDS="rtb-..."
#   CREATE_BEDROCK_ENDPOINT="true"
# ...UNLESS shared services centralize interface endpoints (PHZs associated
# to this VPC) - then creating local private-DNS endpoints FAILS the stack:
# keep CREATE_SUPPORTING_ENDPOINTS=false, and for a centralized
# bedrock-runtime endpoint set BEDROCK_PRIVATE_DNS=false (and apply the
# Claude-only endpoint policy centrally). The S3 GATEWAY endpoint cannot be
# centralized over TGW - create it locally in every case.
# bedrock-runtime endpoint: keeps inference off any NAT/IGW path.
export CREATE_BEDROCK_ENDPOINT="true"
export BEDROCK_PRIVATE_DNS="true"          # false when a centralized bedrock endpoint's PHZ covers this VPC
# Set true for fully-private subnets with no NAT: adds ecr.api, ecr.dkr,
# logs, and secretsmanager interface endpoints (Fargate's own dependencies,
# billed per AZ-hour). With NAT, leave false.
# Either way the gateway needs an egress path to the Okta issuer for OIDC.
export CREATE_SUPPORTING_ENDPOINTS="false"
# Private route table IDs (rtb-aaa,rtb-bbb): when set, creates a FREE S3
# gateway endpoint — recommended in every VPC (keeps ECR image-layer pulls
# off NAT data-processing charges) and required for pulls without NAT.
export PRIVATE_ROUTE_TABLE_IDS=""
