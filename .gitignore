# Per-environment deploy configuration (copy from deploy.env.example)
scripts/deploy.env

# The mirrored claude binary staged for the container build - never commit
docker/claude
docker/claude.exe

# Local release mirrors
client/mirror/
mirror/

# Key material and CSRs from import-enterprise-cert.sh
*.key.pem
*.csr
*.pem

# Python bytecode (local syntax checks)
__pycache__/

# Playwright MCP scratch
.playwright-mcp/

# Local task/handoff briefs (working notes, not repo documentation)
tasks/

# Test artifacts
.pytest_cache/
tests/**/__pycache__/

# Generated Grafana TLS cert (built per-run by build-and-push-grafana.sh)
docker/grafana/tls/

# Generated gateway listener TLS cert (built per-run by build-and-push-image.sh)
docker/tls/

# Generated portal listener TLS cert (built per-run by build-and-push-portal.sh)
docker/portal/tls/

# Agent worktree isolation checkouts (never commit)
.claude/worktrees/
scripts/.rds-ca-bundle.pem
